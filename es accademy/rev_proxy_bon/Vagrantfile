      </p>

      <p>
        <strong>Hostname:</strong> backend1
      </p>

      <p>
        <strong>Indirizzo IP:</strong> 192.168.50.51 NOTO ANCHE COME 1.9.2.7
      </p>

      <div class="status">
        SERVER ONLINE!
      </div>
    </section>

    <footer>
      HAProxy DevOps Lab — Percorso /roma
    </footer>

  </main>
</body>
</html>
EOF
    #avvio nginx
    systemctl enable --now nginx
    #controlla che conf nginx sia corretta
    nginx -t
  SHELL
end

