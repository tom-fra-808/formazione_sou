#configurazione generale
Vagrant.configure("2") do |config|
  config.vm.box = "generic/debian12"
  config.vm.provider "virtualbox" do |vb|
    vb.memory = 768
    vb.cpus = 1
  end 

#backend1 configurazione
config.vm.define "backend1" do |backend1|
  #setting hostname
  backend1.vm.hostname = "backend1" 
  #setting rete
  backend1.vm.network "private_network", ip: "192.168.50.51"
  #provisioning tramite shell
  backend1.vm.provision "shell", inline: <<-SHELL
    #aggiorno elenco pacchetti
    apt-get update
    #installo programmi web e firewall
    apt-get install -y nginx firewalld
    #abilito firewall
    systemctl enable --now firewalld
    #creo una variabile 'zone' in cui identifico la zona corrente del firewall
    ZONE="$(firewall-cmd --get-default-zone)"
    #imposto una regola del firewall backend1 grazie alla quale con http solo frontend può accedervi
    firewall-cmd --permanent --zone="$ZONE" --add-rich-rule='rule family="ipv4" source address="192.168.50.50/32" port port="80" protocol="tcp" accept'
    #ricarico il firewall
    firewall-cmd --reload

    #creo pagina html specifica backend 1 --> FATTA DA AI
    cat > /var/www/html/index.html <<'EOF'
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Backend Roma</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, Helvetica, sans-serif;
      color: white;
      background: linear-gradient(135deg, #8e1f2d, #5c0011);
    }

    .container {
      width: 90%;
      max-width: 750px;
      padding: 45px;
      text-align: center;
      border: 4px solid #f4c542;
      border-radius: 20px;
      background-color: rgba(92, 0, 17, 0.85);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    }

    .logo {
      width: 120px;
      height: 120px;
      margin: 0 auto 25px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 5px solid #f4c542;
      border-radius: 50%;
      color: #f4c542;
      font-size: 52px;
      font-weight: bold;
    }

    h1 {
      margin: 10px 0;
      color: #f4c542;
      font-size: 42px;
    }

    .slogan {
      font-size: 22px;
      font-style: italic;
    }

    .server-info {
      margin-top: 30px;
      padding: 20px;
      border-radius: 12px;
      background-color: rgba(255, 255, 255, 0.1);
    }

    .status {
      display: inline-block;
      margin-top: 15px;
      padding: 8px 18px;
      border-radius: 20px;
      color: #163300;
      background-color: #8fff70;
      font-weight: bold;
    }

    footer {
      margin-top: 30px;
      color: #f4c542;
      font-size: 14px;
    }
  </style>
</head>

<body>
  <main class="container">

    <div class="logo">RM</div>

    <h1>Forza Roma</h1>

    <p class="slogan">
      Benvenuto nel server giallorosso.
    </p>

    <section class="server-info">
      <h2>Backend Roma</h2>

      <p>
