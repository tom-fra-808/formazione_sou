Vagrant.configure("2") do |config|

  config.vm.define "rockybalboaaa" do |rocky|
    rocky.vm.box = "generic/rocky8"
    rocky.vm.hostname = "rockybalboaaa"

    rocky.vm.network "private_network", ip: "192.168.33.13"
    rocky.vm.disk :disk, size: "100GB", name: "rockybalboaaa_secondo_disco"
    rocky.vm.synced_folder "./shared", "/home/vagrant/shared"

    rocky.vm.provider "virtualbox" do |vb|
      vb.name = "rockybalboaaa"
      vb.memory = 1024
      vb.cpus = 1
    end

    rocky.vm.provision "shell", inline: <<-SHELL
      sudo dnf update -y
      sudo dnf install -y lvm2 httpd curl

      # Creazione LVM solo se /dev/sdb non è già inizializzato
      if ! sudo pvs /dev/sdb > /dev/null 2>&1; then
        sudo pvcreate /dev/sdb
        sudo vgcreate vg_rockybalboaaa /dev/sdb
        sudo lvcreate -L 50G -n lv_rockybalboaaa vg_rockybalboaaa
        sudo mkfs.ext4 /dev/vg_rockybalboaaa/lv_rockybalboaaa
      fi

      sudo mkdir -p /mnt/secondo_disco

      if ! mountpoint -q /mnt/secondo_disco; then
        sudo mount /dev/vg_rockybalboaaa/lv_rockybalboaaa /mnt/secondo_disco
      fi

      if ! grep -q "vg_rockybalboaaa" /etc/fstab; then
        echo "/dev/vg_rockybalboaaa/lv_rockybalboaaa /mnt/secondo_disco ext4 defaults 0 0" | sudo tee -a /etc/fstab
      fi

      sudo chown vagrant:vagrant /mnt/secondo_disco
      sudo chmod 755 /mnt/secondo_disco

      # Pagina web del server
      echo "<h1>Ciao, sono rockybalboaaa: il SERVER</h1>" | sudo tee /var/www/html/index.html
      echo "<p>Sto comunicando con ivandrago.</p>" | sudo tee -a /var/www/html/index.html

      sudo systemctl enable --now httpd

      # Firewall, se firewalld è attivo
      if systemctl is-active --quiet firewalld; then
        sudo firewall-cmd --permanent --add-service=http
        sudo firewall-cmd --reload
      fi

      sudo systemctl is-active httpd
    SHELL
  end


  config.vm.define "ivandragooo" do |rocky|
    rocky.vm.box = "generic/rocky8"
    rocky.vm.hostname = "ivandragooo"

    rocky.vm.network "private_network", ip: "192.168.33.14"
    rocky.vm.disk :disk, size: "100GB", name: "ivandragooo_secondo_disco"
    rocky.vm.synced_folder "./shared", "/home/vagrant/shared"

    rocky.vm.provider "virtualbox" do |vb|
      vb.name = "ivandragooo"
      vb.memory = 1024
      vb.cpus = 1
    end

    rocky.vm.provision "shell", inline: <<-SHELL
      sudo dnf update -y
      sudo dnf install -y lvm2 curl

      # Creazione LVM solo se /dev/sdb non è già inizializzato
      if ! sudo pvs /dev/sdb > /dev/null 2>&1; then
        sudo pvcreate /dev/sdb
        sudo vgcreate vg_ivandragooo /dev/sdb
        sudo lvcreate -L 50G -n lv_ivandragooo vg_ivandragooo
        sudo mkfs.ext4 /dev/vg_ivandragooo/lv_ivandragooo
      fi

      sudo mkdir -p /mnt/secondo_disco

      if ! mountpoint -q /mnt/secondo_disco; then
        sudo mount /dev/vg_ivandragooo/lv_ivandragooo /mnt/secondo_disco
      fi

      if ! grep -q "vg_ivandragooo" /etc/fstab; then
        echo "/dev/vg_ivandragooo/lv_ivandragooo /mnt/secondo_disco ext4 defaults 0 0" | sudo tee -a /etc/fstab
      fi

      sudo chown vagrant:vagrant /mnt/secondo_disco
      sudo chmod 755 /mnt/secondo_disco

      # Script client per testare il server
      cat << 'EOF' > /home/vagrant/test_server.sh
#!/bin/bash

echo "Test ping verso il server rockybalboaaa..."
ping -c 4 192.168.33.10

echo
echo "Test HTTP verso il server rockybalboaaa..."
curl http://192.168.33.10
EOF

      chmod +x /home/vagrant/test_server.sh
      chown vagrant:vagrant /home/vagrant/test_server.sh
    SHELL
  end

end